#:kivy 2.3.0

# === 单词测验页 ===
<QuizScreen>:
    BoxLayout:
        orientation: 'vertical'
        padding: [30, 20]
        spacing: 20

        # 标题栏 + 进度
        BoxLayout:
            size_hint_y: None
            height: 60
            Label:
                text: '单词测验'
                font_size: 40
                bold: True
                color: app.color_text
                halign: 'left'
                valign: 'middle'
                text_size: self.size
                size_hint_x: 0.7
            Label:
                id: progress_label
                text: ''
                font_size: 28
                color: app.color_accent
                halign: 'right'
                valign: 'middle'
                text_size: self.size
                size_hint_x: 0.3

        # 主内容卡片
        BoxLayout:
            orientation: 'vertical'
            id: quiz_content
            spacing: 20
            padding: [30, 24]
            canvas.before:
                Color:
                    rgba: app.color_shadow
                RoundedRectangle:
                    pos: self.x + 2, self.y - 2
                    size: self.width + 2, self.height + 2
                    radius: [20]
                Color:
                    rgba: app.color_bg_card
                RoundedRectangle:
                    pos: self.pos
                    size: self.size
                    radius: [16]

            # 题干: 英文单词
            Label:
                id: question_word
                text: ''
                font_size: 56
                bold: True
                color: app.color_text
                size_hint_y: None
                height: 80

            # 分隔线
            Label:
                size_hint_y: None
                height: 2
                canvas.before:
                    Color:
                        rgba: app.color_border
                    Rectangle:
                        pos: self.pos
                        size: self.size

            # 选项区: 5个选项按钮
            GridLayout:
                id: choices_grid
                cols: 1
                spacing: 12
                size_hint_y: None
                height: self.minimum_height

            # 对错提示
            Label:
                id: feedback_label
                text: ''
                font_size: 30
                bold: True
                color: app.color_success
                size_hint_y: None
                height: 50

            # 操作按钮区 (居中)
            AnchorLayout:
                size_hint_y: None
                height: 60
                anchor_x: 'center'
                BoxLayout:
                    size_hint_x: None
                    width: 200
                    # 确定按钮
                    Button:
                        id: confirm_btn
                        text: '确定'
                        font_size: 28
                        background_normal: ''
                        background_down: ''
                        background_color: app.color_accent
                        color: (1, 1, 1, 1)
                        disabled: True
                        on_press: root.confirm_answer()

                    # 下一题按钮
                    Button:
                        id: next_btn
                        text: '下一题'
                        font_size: 28
                        background_normal: ''
                        background_down: ''
                        background_color: app.color_accent
                        color: (1, 1, 1, 1)
                        disabled: True
                        opacity: 0
                        on_press: root.next_question()

        # 底部统计
        Label:
            id: stats_label
            text: ''
            font_size: 24
            color: app.color_text_sec
            size_hint_y: None
            height: 40

        # 空状态提示
        Label:
            id: empty_message
            text: ''
            font_size: 36
            color: app.color_text_sec
            halign: 'center'
            valign: 'middle'
            text_size: self.size
            size_hint_y: None
            height: 0
